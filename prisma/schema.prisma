// =====================================================
// 16. ATTRIBUTE MANAGEMENT
// =====================================================

model Attribute {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  code        String?   @db.VarChar(50)
  dataType    String?   @map("data_type") @db.VarChar(50)
  unit        String?   @db.VarChar(50)
  description String?   @db.VarChar(255)
  status      String    @default("active") @db.VarChar(20)
  createdBy   Int?      @map("created_by")
  updatedBy   Int?      @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  creator              User?                 @relation("AttributeCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater              User?                 @relation("AttributeUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  productHasAttributes ProductHasAttribute[]

  @@index([status])
  @@map("attributes")
}

model ProductHasAttribute {
  id          Int     @id @default(autoincrement())
  productId   Int     @map("product_id")
  attributeId Int     @map("attribute_id")
  value       String? @db.VarChar(255)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([attributeId])
  @@map("product_has_attributes")
}

model ProductUnitConversion {
  id               Int      @id @default(autoincrement())
  productId        Int      @map("product_id")
  unitId           Int      @map("unit_id")
  conversionFactor Decimal  @map("conversion_factor") @db.Decimal(15, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  unit    Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([productId, unitId])
  @@index([productId])
  @@index([unitId])
  @@map("product_unit_conversions")
}
