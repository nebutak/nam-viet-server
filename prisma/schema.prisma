// ==================== NEWS MODULE ====================

enum NewsStatus {
  draft
  published
  archived
}

enum ContentType {
  article
  video
}

// News Category
model NewsCategory {
  id           Int        @id @default(autoincrement())
  categoryKey  String     @unique @map("category_key") @db.VarChar(50)
  categoryName String     @map("category_name") @db.VarChar(100)
  description  String?    @db.Text
  slug         String     @unique @db.VarChar(100)
  displayOrder Int        @default(0) @map("display_order")
  status       RoleStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  news News[]

  @@index([status, displayOrder])
  @@map("news_categories")
}

// News Tag
model NewsTag {
  id        Int       @id @default(autoincrement())
  tagName   String    @unique @map("tag_name") @db.VarChar(50)
  slug      String    @unique @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  newsTagRelations NewsTagRelation[]

  @@map("news_tags")
}

// News
model News {
  id              Int         @id @default(autoincrement())
  title           String      @db.VarChar(255)
  slug            String      @unique @db.VarChar(255)
  excerpt         String?     @db.Text
  content         String      @db.LongText
  contentType     ContentType @default(article) @map("content_type")
  featuredImage   String?     @map("featured_image") @db.VarChar(255)
  videoFile       String?     @map("video_file") @db.VarChar(500)
  videoThumbnail  String?     @map("video_thumbnail") @db.VarChar(255)
  videoDuration   Int?        @map("video_duration")
  categoryId      Int         @map("category_id")
  authorId        Int         @map("author_id")
  status          NewsStatus  @default(draft)
  publishedAt     DateTime?   @map("published_at")
  viewCount       Int         @default(0) @map("view_count")
  likeCount       Int         @default(0) @map("like_count")
  commentCount    Int         @default(0) @map("comment_count")
  isFeatured      Boolean     @default(false) @map("is_featured")
  metaTitle       String?     @map("meta_title") @db.VarChar(255)
  metaDescription String?     @map("meta_description") @db.Text
  metaKeywords    String?     @map("meta_keywords") @db.VarChar(255)
  createdBy       Int?        @map("created_by")
  updatedBy       Int?        @map("updated_by")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  category         NewsCategory      @relation(fields: [categoryId], references: [id])
  author           User              @relation("NewsAuthor", fields: [authorId], references: [id])
  creator          User?             @relation("NewsCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater          User?             @relation("NewsUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  newsTagRelations NewsTagRelation[]

  @@index([categoryId, status, publishedAt])
  @@index([authorId])
  @@index([isFeatured, status])
  @@index([contentType, status])
  @@map("news")
}

// News Tag Relation (Many-to-Many)
model NewsTagRelation {
  newsId Int @map("news_id")
  tagId  Int @map("tag_id")

  news News    @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag  NewsTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([newsId, tagId])
  @@map("news_tag_relations")
}

