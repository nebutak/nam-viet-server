  checkInTime      DateTime?        @map("check_in_time") @db.Time()
  checkOutTime     DateTime?        @map("check_out_time") @db.Time()
  overtimeHours    Decimal          @default(0) @map("overtime_hours") @db.Decimal(5, 2)
  status           AttendanceStatus @default(present)
