model GeneralSetting {
  id        Int      @id @default(autoincrement())
  brandName String   @map("brand_name") @db.VarChar(200)
  logo      String?  @db.VarChar(500)
  name      String   @db.VarChar(200)
  email     String   @db.VarChar(100)
  phone     String   @db.VarChar(20)
  address   String   @db.VarChar(255)
  taxCode   String   @map("tax_code") @db.VarChar(50)
  website   String   @db.VarChar(255)
  banks     String?  @db.LongText // Store as JSON string array of bank accounts
  updatedBy Int?     @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  updater User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("general_settings")
}

// =====================================================
// 11. LOGIN HISTORY
// =====================================================

model LoginHistory {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  userAgent String    @map("user_agent") @db.VarChar(500)
  ipAddress String    @map("ip_address") @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  logoutAt  DateTime? @map("logout_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("login_histories")
}

// =====================================================
// 12. USER PERMISSIONS
// =====================================================

model UserPermission {
  userId       Int       @map("user_id")
  permissionId Int       @map("permission_id")
  grantType    GrantType @default(grant) // grant: thêm quyền, revoke: bỏ quyền
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedBy   Int?      @map("assigned_by")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assigner   User?      @relation("PermissionAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, permissionId])
  @@index([userId, grantType])
  @@map("user_permissions")
}

enum GrantType {
  grant // Thêm quyền
  revoke // Bỏ quyền (dùng để override quyền từ role)
}

// =====================================================
// 13. CRM SYSTEM (Tickets & Tasks)
// =====================================================

model Ticket {
  id           Int            @id @default(autoincrement())
  ticketCode   String         @unique @map("ticket_code") @db.VarChar(50)
  title        String         @db.VarChar(200)
  description  String?        @db.Text
  status       TicketStatus   @default(open)
  priority     TicketPriority @default(medium)
  customerId   Int            @map("customer_id")
  assignedToId Int?           @map("assigned_to_id")
  createdBy    Int            @map("created_by")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  customer   Customer  @relation(fields: [customerId], references: [id])
  assignedTo User?     @relation("TicketAssignee", fields: [assignedToId], references: [id])
  creator    User      @relation("TicketCreator", fields: [createdBy], references: [id])
  tasks      CrmTask[]

  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([assignedToId])
  @@map("tickets")
}

model CrmTask {
  id              Int          @id @default(autoincrement())
  title           String       @db.VarChar(200)
  description     String?      @db.Text
  dueDate         DateTime?    @map("due_date")
  status          TaskStatus   @default(pending)
  priority        TaskPriority @default(medium)
  type            TaskType     @default(call)
  customerId      Int          @map("customer_id")
  assignedToId    Int?         @map("assigned_to_id")
  relatedTicketId Int?         @map("related_ticket_id")
  createdBy       Int          @map("created_by")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  customer      Customer @relation(fields: [customerId], references: [id])
  assignedTo    User?    @relation("TaskAssignee", fields: [assignedToId], references: [id])
  relatedTicket Ticket?  @relation(fields: [relatedTicketId], references: [id])
  creator       User     @relation("TaskCreator", fields: [createdBy], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([assignedToId])
  @@map("crm_tasks")
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskType {
  call
  email
  meeting
  other
}

model Material {
  id            Int       @id @default(autoincrement())
  materialCode  String    @unique @map("material_code") @db.VarChar(50)
  name          String    @db.VarChar(200)
  cost          Decimal   @db.Decimal(15, 2)
  supplierId    Int?      @map("supplier_id")
  categoryId    Int?      @map("category_id")
  unit          String?   @db.VarChar(50)
  materialType  String?   @map("material_type") @db.VarChar(100)
  priority      Int       @default(0)
  purchaseDate  DateTime? @map("purchase_date") @db.Date
  effectiveDate DateTime? @map("effective_date") @db.Date
  imageUrl      String?   @map("image_url") @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  supplier Supplier?         @relation(fields: [supplierId], references: [id])
  category Category?         @relation(fields: [categoryId], references: [id])
  products ProductMaterial[]

  @@index([supplierId])
  @@index([categoryId])
  @@index([materialCode])
  @@map("materials")
}

model ProductMaterial {
  productId  Int      @map("product_id")
  materialId Int      @map("material_id")
  createdAt  DateTime @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@id([productId, materialId])
  @@index([productId])
  @@index([materialId])
  @@map("product_materials")
}

// =====================================================
