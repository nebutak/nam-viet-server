model Unit {
  id          Int        @id @default(autoincrement())
  unitCode    String     @unique @map("unit_code") @db.VarChar(50)
  unitName    String     @map("unit_name") @db.VarChar(100)
  description String?    @db.VarChar(255)
  status      UnitStatus @default(active)
  createdBy   Int?       @map("created_by")
  updatedBy   Int?       @map("updated_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  creator         User?                   @relation("UnitCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater         User?                   @relation("UnitUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  products        Product[]
  unitConversions ProductUnitConversion[]

  @@index([unitCode])
  @@index([status])
  @@map("units")
}

